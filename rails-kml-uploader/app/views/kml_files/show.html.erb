<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1><%= @kml_file.name %></h1>
    <div class="d-flex align-items-center gap-3">
      <%= render 'status_badge', kml_file: @kml_file %>
      <small class="text-muted">
        Uploaded <%= @kml_file.created_at.strftime("%B %d, %Y at %l:%M %p") %>
      </small>
    </div>
  </div>
  
  <div>
    <%= link_to "Back to KML Files", kml_files_path, class: "btn btn-outline-secondary" %>
    <% if current_user.can_delete_data? %>
      <%= link_to "Delete", kml_file_path(@kml_file), method: :delete, 
          confirm: "Are you sure you want to delete this KML file and all its data?", 
          class: "btn btn-outline-danger" %>
    <% end %>
  </div>
</div>

<% if @kml_file.failed? %>
  <div class="alert alert-danger">
    <h5>Processing Failed</h5>
    <p class="mb-0"><%= @kml_file.error_details %></p>
  </div>
<% elsif @kml_file.processing? %>
  <div class="alert alert-info">
    <div class="d-flex align-items-center">
      <div class="spinner-border spinner-border-sm me-2" role="status"></div>
      <div>
        <strong>Processing in progress...</strong>
        <div>Your KML file is being parsed and processed. This page will automatically update when complete.</div>
      </div>
    </div>
  </div>
<% elsif @kml_file.completed? %>
  
  <!-- Summary Stats -->
  <div class="row mb-4">
    <div class="col-md-3">
      <div class="card text-center">
        <div class="card-body">
          <div class="text-primary h2 mb-0"><%= @kml_file.controllers_count %></div>
          <div class="text-muted">Controllers</div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card text-center">
        <div class="card-body">
          <div class="text-success h2 mb-0"><%= @kml_file.zones_count %></div>
          <div class="text-muted">Zones</div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card text-center">
        <div class="card-body">
          <div class="text-info h2 mb-0"><%= @kml_file.file_size_humanized %></div>
          <div class="text-muted">File Size</div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card text-center">
        <div class="card-body">
          <div class="text-warning h2 mb-0">
            <%= @controllers.sum(&:coverage_area).round(1) %>
          </div>
          <div class="text-muted">Total Acres</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Interactive Map -->
  <div class="card mb-4" id="map">
    <div class="card-header">
      <h5 class="mb-0">Interactive Map</h5>
    </div>
    <div class="card-body p-0">
      <div id="kml-map" class="map-container" 
           data-controller="kml-map" 
           data-kml-map-url-value="<%= map_data_kml_file_path(@kml_file) %>">
      </div>
    </div>
  </div>

  <!-- Controllers Table -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">Controllers (<%= @controllers.count %>)</h5>
    </div>
    <div class="card-body">
      <% if @controllers.any? %>
        <div class="table-responsive">
          <table class="table table-hover">
            <thead>
              <tr>
                <th>Name</th>
                <th>Location</th>
                <th>Model</th>
                <th>Stations</th>
                <th>Zones</th>
                <th>Coverage</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @controllers.each do |controller| %>
                <tr>
                  <td>
                    <strong><%= controller.name %></strong>
                    <% if controller.serial_number %>
                      <br><small class="text-muted">SN: <%= controller.serial_number %></small>
                    <% end %>
                  </td>
                  <td>
                    <small class="text-muted">
                      <%= controller.latitude.round(6) %>, <%= controller.longitude.round(6) %>
                    </small>
                  </td>
                  <td><%= controller.model || '-' %></td>
                  <td><%= controller.station_count %></td>
                  <td>
                    <span class="badge bg-primary"><%= controller.zones_count %></span>
                  </td>
                  <td><%= controller.coverage_area %> acres</td>
                  <td>
                    <%= link_to "View", controller_path(controller), class: "btn btn-sm btn-outline-primary" %>
                    <% if current_user.can_delete_data? %>
                      <%= link_to "Delete", controller_path(controller), method: :delete,
                          confirm: "Delete this controller and all its zones?",
                          class: "btn btn-sm btn-outline-danger" %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-muted text-center py-3">No controllers found in this KML file.</p>
      <% end %>
    </div>
  </div>

  <!-- Zones Table -->
  <div class="card">
    <div class="card-header">
      <h5 class="mb-0">Zones (<%= @zones.count %>)</h5>
    </div>
    <div class="card-body">
      <% if @zones.any? %>
        <div class="table-responsive">
          <table class="table table-hover">
            <thead>
              <tr>
                <th>Name</th>
                <th>Controller</th>
                <th>Station</th>
                <th>Type</th>
                <th>Boundary</th>
                <th>Area</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @zones.each do |zone| %>
                <tr>
                  <td><strong><%= zone.name %></strong></td>
                  <td><%= zone.controller.name %></td>
                  <td><span class="badge bg-secondary"><%= zone.station_number %></span></td>
                  <td>
                    <span class="badge bg-info"><%= zone.zone_type.titleize %></span>
                  </td>
                  <td>
                    <small class="text-muted"><%= zone.boundary_type %></small>
                  </td>
                  <td>
                    <% if zone.area_acres > 0 %>
                      <%= zone.area_acres %> acres
                    <% else %>
                      -
                    <% end %>
                  </td>
                  <td>
                    <%= link_to "View", controller_zone_path(zone.controller, zone), 
                        class: "btn btn-sm btn-outline-primary" %>
                    <% if current_user.can_delete_data? %>
                      <%= link_to "Delete", controller_zone_path(zone.controller, zone), 
                          method: :delete, confirm: "Delete this zone?",
                          class: "btn btn-sm btn-outline-danger" %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-muted text-center py-3">No zones found in this KML file.</p>
      <% end %>
    </div>
  </div>

<% end %>

<!-- Auto-refresh for processing status -->
<% if @kml_file.processing? %>
  <script>
    setTimeout(() => {
      window.location.reload();
    }, 3000);
  </script>
<% end %>