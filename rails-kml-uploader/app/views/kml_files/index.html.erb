<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>KML Files</h1>
  <% if current_user.can_upload_kml? %>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#uploadModal">
      Upload KML File
    </button>
  <% end %>
</div>

<% if @kml_files.any? %>
  <div class="row">
    <% @kml_files.each do |kml_file| %>
      <div class="col-md-6 col-lg-4 mb-4">
        <div class="card h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <h5 class="card-title"><%= kml_file.name %></h5>
              <%= render 'status_badge', kml_file: kml_file %>
            </div>
            
            <div class="row text-center mb-3">
              <div class="col-6">
                <div class="text-primary h4 mb-0"><%= kml_file.controllers_count %></div>
                <small class="text-muted">Controllers</small>
              </div>
              <div class="col-6">
                <div class="text-success h4 mb-0"><%= kml_file.zones_count %></div>
                <small class="text-muted">Zones</small>
              </div>
            </div>
            
            <div class="mb-3">
              <small class="text-muted d-block">Size: <%= kml_file.file_size_humanized %></small>
              <small class="text-muted d-block">Uploaded: <%= kml_file.created_at.strftime("%b %d, %Y") %></small>
              <% if kml_file.processed_at %>
                <small class="text-muted d-block">Processed: <%= kml_file.processed_at.strftime("%b %d, %Y") %></small>
              <% end %>
            </div>
            
            <% if kml_file.failed? && kml_file.error_message %>
              <div class="alert alert-danger alert-sm mb-3">
                <small><%= kml_file.error_message %></small>
              </div>
            <% end %>
          </div>
          
          <div class="card-footer bg-transparent">
            <div class="d-flex gap-2">
              <%= link_to "View", kml_file_path(kml_file), class: "btn btn-outline-primary btn-sm flex-fill" %>
              <% if kml_file.completed? %>
                <%= link_to "Map", kml_file_path(kml_file, anchor: "map"), class: "btn btn-outline-success btn-sm flex-fill" %>
              <% end %>
              <% if current_user.can_delete_data? %>
                <%= link_to "Delete", kml_file_path(kml_file), method: :delete, 
                    confirm: "Are you sure?", class: "btn btn-outline-danger btn-sm" %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-5">
    <div class="mb-4">
      <svg class="text-muted" width="64" height="64" fill="currentColor" viewBox="0 0 16 16">
        <path d="M14 14V4.5L9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2zM9.5 3A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5v2z"/>
      </svg>
    </div>
    <h4 class="text-muted">No KML files uploaded yet</h4>
    <p class="text-muted">Upload your first KML file to get started with controller and zone visualization.</p>
    <% if current_user.can_upload_kml? %>
      <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#uploadModal">
        Upload Your First KML File
      </button>
    <% end %>
  </div>
<% end %>

<!-- Upload Modal -->
<% if current_user.can_upload_kml? %>
  <div class="modal fade" id="uploadModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Upload KML File</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <%= form_with url: upload_kml_files_path, multipart: true, data: { controller: "kml-upload" } do |form| %>
            <div class="mb-3">
              <%= form.label :name, class: "form-label" %>
              <%= form.text_field :name, class: "form-control", placeholder: "Enter a name for this KML file" %>
            </div>
            
            <div class="mb-3">
              <label class="form-label">KML File</label>
              <div class="dropzone" data-kml-upload-target="dropzone">
                <div class="mb-3">
                  <svg class="text-muted mb-2" width="48" height="48" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8.5 11.5a.5.5 0 0 1-1 0V6.707L5.354 8.854a.5.5 0 1 1-.708-.708l3-3a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 6.707V11.5z"/>
                    <path d="M14 14V4.5L9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2zM9.5 3A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5v2z"/>
                  </svg>
                  <div>Drag & drop your KML file here</div>
                  <div class="text-muted">or click to browse</div>
                </div>
                <%= form.file_field :file, accept: ".kml", class: "d-none", data: { kml_upload_target: "fileInput" } %>
              </div>
              <div class="form-text">Accepts .kml files containing irrigation controller and zone data.</div>
            </div>
            
            <div data-kml-upload-target="uploadProgress" class="d-none">
              <div class="progress mb-3">
                <div class="progress-bar progress-bar-striped progress-bar-animated" style="width: 0%"></div>
              </div>
              <div class="text-center">
                <small class="text-muted">Processing KML file...</small>
              </div>
            </div>
            
            <div class="modal-footer px-0 pb-0">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="btn btn-primary" data-kml-upload-target="submitButton">Upload</button>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<%= render 'status_badge_partial' %>