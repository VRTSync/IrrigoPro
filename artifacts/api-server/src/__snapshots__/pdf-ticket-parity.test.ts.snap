{
  "ticketPageBS": "\n  <div class=\"ticket-page\">\n    <div class=\"ticket-header ticket-header-bs\">\n      <div class=\"ticket-header-condensed\">\n        \n        <div class=\"ticket-header-line1\">Billing Sheet #BS-PARITY-TEST &nbsp;|&nbsp; Invoice #INV-PARITY-001</div>\n        <div class=\"ticket-header-line2\">Date: May 20, 2026 &nbsp;|&nbsp; Technician: Parity Tech &nbsp;|&nbsp; Hours: 3 hrs</div>\n        <div class=\"ticket-header-line3\">&#128205; 42 Parity Lane, Springfield</div>\n        \n        <div class=\"ticket-approval\">\n         <span class=\"ticket-approval-icon\">&#10003;</span>\n         <div class=\"ticket-approval-details\">\n           <span class=\"ticket-approval-by\">Approved By: <strong>Manager Parity</strong></span>\n           <span class=\"ticket-approval-at\">Approved At: May 20, 2026</span>\n         </div>\n       </div>\n      </div>\n    </div>\n\n    <div class=\"ticket-section\">\n         <div class=\"ticket-section-label\">WORK PERFORMED</div>\n         <div class=\"ticket-work-list\"><ul class=\"work-bullet-list\"><li>Replaced rotor heads and adjusted zones</li></ul></div>\n       </div>\n\n    <div class=\"ticket-section ticket-financial\">\n      <div class=\"ticket-section-label\">FINANCIAL BREAKDOWN</div>\n      <div class=\"ticket-fin-rows\">\n        <div class=\"ticket-fin-row\">\n          <span class=\"ticket-fin-label\">Irrigation Labor (3 hrs × $85.00/hr)</span>\n          <span class=\"ticket-fin-value\">$255.00</span>\n        </div>\n        <div class=\"ticket-fin-row\">\n          <span class=\"ticket-fin-label\">Parts Subtotal</span>\n          <span class=\"ticket-fin-value\">$100.00</span>\n        </div>\n        <div class=\"ticket-fin-row ticket-fin-total\">\n          <span class=\"ticket-fin-label\">TOTAL</span>\n          <span class=\"ticket-fin-value\">$355.00</span>\n        </div>\n      </div>\n    </div>\n\n    \n  <div class=\"ticket-section ticket-parts-section\">\n    <div class=\"ticket-section-label\">PARTS &amp; LABOR DETAILS</div>\n    <table class=\"items-table\">\n      <thead>\n        <tr>\n          <th>Part Description</th>\n          <th class=\"text-right\">Qty</th>\n          <th class=\"text-right\">Unit Price</th>\n          <th class=\"text-right\">Labor Hrs</th>\n          <th class=\"text-right\">Total</th>\n        </tr>\n      </thead>\n      <tbody>\n      <tr>\n        <td>Rotor Head<br><small class=\"item-note\">Hunter PGP Rotor</small></td>\n        <td class=\"text-right\">2</td>\n        <td class=\"text-right\">$50.00</td>\n        <td class=\"text-right\">1</td>\n        <td class=\"text-right\">$100.00</td>\n      </tr></tbody>\n    </table>\n  </div>\n\n    \n    \n    <div class=\"ticket-section ticket-photos-section\">\n      <div class=\"ticket-section-label\">WORK PHOTOS</div>\n      <div class=\"photo-no-photos\">No photos captured for this service</div>\n    </div>\n  </div>",
  "ticketPageWCB": "\n  <div class=\"ticket-page\">\n    <div class=\"ticket-header ticket-header-bs\">\n      <div class=\"ticket-header-condensed\">\n        \n        <div class=\"ticket-header-line1\">WC Billing #WCB-PARITY-TEST &nbsp;|&nbsp; Invoice #INV-PARITY-001</div>\n        <div class=\"ticket-header-line2\">Date: May 20, 2026 &nbsp;|&nbsp; Technician: Parity Tech &nbsp;|&nbsp; Hours: 3 hrs</div>\n        <div class=\"ticket-header-line3\">&#128205; 42 Parity Lane, Springfield</div>\n        \n        <div class=\"ticket-approval\">\n         <span class=\"ticket-approval-icon\">&#10003;</span>\n         <div class=\"ticket-approval-details\">\n           <span class=\"ticket-approval-by\">Approved By: <strong>Manager Parity</strong></span>\n           <span class=\"ticket-approval-at\">Approved At: May 20, 2026</span>\n         </div>\n       </div>\n      </div>\n    </div>\n\n    <div class=\"ticket-section ticket-financial\">\n      <div class=\"ticket-section-label\">FINANCIAL BREAKDOWN</div>\n      <div class=\"ticket-fin-rows\">\n        <div class=\"ticket-fin-row\">\n          <span class=\"ticket-fin-label\">Irrigation Labor (3 hrs × $85.00/hr)</span>\n          <span class=\"ticket-fin-value\">$255.00</span>\n        </div>\n        <div class=\"ticket-fin-row\">\n          <span class=\"ticket-fin-label\">Parts Subtotal</span>\n          <span class=\"ticket-fin-value\">$100.00</span>\n        </div>\n        <div class=\"ticket-fin-row ticket-fin-total\">\n          <span class=\"ticket-fin-label\">TOTAL</span>\n          <span class=\"ticket-fin-value\">$355.00</span>\n        </div>\n      </div>\n    </div>\n\n    \n  <div class=\"ticket-section ticket-parts-section\">\n    <div class=\"ticket-section-label\">Repairs Summary &mdash; 1 repair across 1 zone</div>\n    <table class=\"items-table\">\n      <thead>\n        <tr>\n          <th>Repair Type</th>\n          <th class=\"text-right\">Part</th>\n          <th class=\"text-right\">Qty</th>\n          <th class=\"text-right\">Unit Price</th>\n          <th class=\"text-right\">Parts Total</th>\n        </tr>\n      </thead>\n      <tbody>\n      <tr>\n        <td>Head Replacement</td>\n        <td class=\"text-right\">Rotor Head</td>\n        <td class=\"text-right\">2</td>\n        <td class=\"text-right\">$50.00</td>\n        <td class=\"text-right\">$100.00</td>\n      </tr></tbody>\n    </table>\n  </div>\n  <div class=\"zone-block\">\n    <div class=\"ticket-section ticket-parts-section\">\n      <div class=\"ticket-section-label\">Zone A-1</div>\n      <table class=\"items-table\">\n        <thead>\n          <tr>\n            <th>Repair Type</th>\n            <th class=\"text-right\">Part</th>\n            <th class=\"text-right\">Qty</th>\n            <th class=\"text-right\">Unit Price</th>\n            <th class=\"text-right\">Parts Total</th>\n          </tr>\n        </thead>\n        <tbody>\n          \n      <tr>\n        <td>Head Replacement</td>\n        <td class=\"text-right\">Rotor Head</td>\n        <td class=\"text-right\">2</td>\n        <td class=\"text-right\">$50.00</td>\n        <td class=\"text-right\">$100.00</td>\n      </tr>\n          \n      <tr class=\"zone-subtotal-row\">\n        <td colspan=\"4\" style=\"font-weight:700; color:#000000;\">Zone A-1 Subtotal</td>\n        <td class=\"text-right\" style=\"font-weight:700; color:#8B4F2B;\">$100.00</td>\n      </tr>\n        </tbody>\n      </table>\n    </div>\n    \n  </div>\n\n    \n    \n    <div class=\"ticket-section ticket-photos-section\">\n      <div class=\"ticket-section-label\">WORK PHOTOS</div>\n      <div class=\"photo-no-photos\">No photos captured for this service</div>\n    </div>\n  </div>"
