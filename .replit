modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "auth-middleware-coverage"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "company-id-backfill-migration"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "pdf-cover-header"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "wc-customer-picker-filter"

[[workflows.workflow]]
name = "auth-middleware-coverage"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server exec node --import tsx --test --test-reporter=spec src/routes/auth-middleware-coverage.test.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "company-id-backfill-migration"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server exec node --import tsx/esm --test --test-reporter=spec src/migrations/0004-company-id-backfill.test.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "pdf-cover-header"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server exec node --import tsx --test --test-reporter=spec src/pdf-cover-header.test.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "wc-customer-picker-filter"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/irrigopro exec vitest run src/pages/wet-checks/CustomerPickerPage.test.tsx"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 6000

[[ports]]
localPort = 8083
externalPort = 6800

[[ports]]
localPort = 18522
externalPort = 3003

[[ports]]
localPort = 21025
externalPort = 3000

[[ports]]
localPort = 21209
externalPort = 3001

[[ports]]
localPort = 23333
externalPort = 3002

[[ports]]
localPort = 23334
externalPort = 5173

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
USE_DB_OAUTH_STATE = "1"
